{
    "swagger": "2.0",
    "info": {
        "description": "API for WhatsApp automation using WhatsMeow.",
        "title": "WhatsMeow Basileia API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:3179",
    "basePath": "/api",
    "paths": {
        "/device": {
            "get": {
                "description": "Returns a list of all active device IDs",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "device"
                ],
                "summary": "List devices",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Generates a new device ID and initializes a client",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "device"
                ],
                "summary": "Create a new device",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/device/{id}/qr": {
            "get": {
                "description": "Connects to SSE stream to receive QR codes for pairing",
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "device"
                ],
                "summary": "Get QR code stream",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {}
            }
        },
        "/device/{id}/status": {
            "get": {
                "description": "Returns the connection status of the device",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "device"
                ],
                "summary": "Get device status",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Device ID (JID)",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/message/send": {
            "post": {
                "description": "Sends a text message to a specific phone number",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "message"
                ],
                "summary": "Send a message",
                "parameters": [
                    {
                        "description": "Message Request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.SendMessageRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.SendMessageRequest": {
            "type": "object",
            "properties": {
                "buttons": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "device_id": {
                    "type": "string"
                },
                "footer": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "phone": {
                    "type": "string"
                }
            }
        }
    }
}